PORT=5000
GEMINI_API_KEY=your_gemini_api_key_here
CHROMA_URL=http://localhost:8000
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_PROJECT_ID=local-ai-assistant

# Set to false in production to use real Cloud Firestore
USE_MOCK_DATABASE=true

# Add comma-separated origins allowed to access the API in production (e.g. your Vercel URL)
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Firebase service account credentials as a single JSON string (production setup)
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "..."}

# --- Embedding Rate Limiting (Pacing) ---
# Option A: Explicit delay in milliseconds between embedding calls
EMBED_BATCH_DELAY_MS=1200

# Option B: Cap of requests per minute (delay is auto-computed with a 10% safety buffer)
# EMBED_REQUESTS_PER_MINUTE=100
