PORT=5000
GEMINI_API_KEY=your_gemini_api_key_here
CHROMA_URL=http://localhost:8000
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_PROJECT_ID=local-ai-assistant

# --- Embedding Rate Limiting (Pacing) ---
# Option A: Explicit delay in milliseconds between embedding calls
EMBED_BATCH_DELAY_MS=1200

# Option B: Cap of requests per minute (delay is auto-computed with a 10% safety buffer)
# EMBED_REQUESTS_PER_MINUTE=100
