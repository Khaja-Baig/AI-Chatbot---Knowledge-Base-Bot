{
  "name": "ai-knowledge-assistant-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend services for AI Knowledge Assistant Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "chroma:start": "bash -c 'source venv/bin/activate && chroma run --path ./data/chroma_db --port 8000'",
    "ingest": "node scripts/ingest_raw_data.js"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "chromadb": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.1.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
